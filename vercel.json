{
  "version": 2,
  "builds": [
    { "src": "api/sos.py", "use": "@vercel/python" },
    { "src": "api/incidents.py", "use": "@vercel/python" },
    { "src": "api/dispatch.py", "use": "@vercel/python" },
    { "src": "api/gps.py", "use": "@vercel/python" },
    { "src": "api/auth.py", "use": "@vercel/python" },
    { "src": "api/volunteers.py", "use": "@vercel/python" }
  ],
  "rewrites": [
    { "source": "/api/sos(.*)", "destination": "api/sos.py" },
    { "source": "/api/incidents(.*)", "destination": "api/incidents.py" },
    { "source": "/api/dispatch(.*)", "destination": "api/dispatch.py" },
    { "source": "/api/gps(.*)", "destination": "api/gps.py" },
    { "source": "/api/auth(.*)", "destination": "api/auth.py" },
    { "source": "/api/volunteers(.*)", "destination": "api/volunteers.py" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/citizen", "destination": "/citizen.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PATCH,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Authorization,Content-Type,X-Admin-Secret" }
      ]
    }
  ]
}
